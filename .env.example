OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_VISION_MODEL=gpt-4.1

# Use DeepSeek for image recognition and text advice.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_VISION_MODEL=deepseek-v4-pro
DEEPSEEK_TEXT_MODEL=deepseek-v4-flash

# Set false only if your DeepSeek account/model rejects image_url input.
DEEPSEEK_ENABLE_IMAGE_INPUT=true

# If your network needs a proxy, uncomment and set your local proxy port:
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
